{
  "expo": {
    "name": "AnySing",
    "slug": "anysing",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/splash-icon-2.png",
    "scheme": "anysing",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF7A00"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anysing.app"
    },
    "android": {
      "package": "com.anysing.app",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash-icon-2.png",
        "backgroundColor": "#FF7A00"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 168,
          "resizeMode": "contain",
          "backgroundColor": "#FF7A00"
        }
      ],
      "expo-video",
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.anysing.app",
          "enableGooglePay": true
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "115d09e1-9957-4c0a-aab2-93fb55241fcc"
      }
    }
  }
}
